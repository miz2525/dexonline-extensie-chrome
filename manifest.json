{
  "manifest_version": 3,
  "name": "Dicționar DEX",
  "version": "1.0.0",
  "description": "Caută definiții românești pe dexonline.ro direct din pagină sau din bara de unelte.",
  "permissions": ["activeTab", "contextMenus"],
  "host_permissions": ["https://dexonline.ro/*"],
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Dicționar DEX",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png"
    }
  }
}
